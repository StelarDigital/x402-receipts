    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "viem": "2.55.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
