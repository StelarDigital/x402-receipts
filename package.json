{
  "name": "x402-receipts",
  "version": "0.4.1",
  "description": "Signed proof-of-delivery receipts for x402 machine-commerce sellers",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
